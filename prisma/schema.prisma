generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  firstName           String?
  lastName            String?
  refreshToken        String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  company             Company?
}

model VerificationCode {
  id        String           @id @default(cuid())
  email     String
  code      String
  type      VerificationType
  payload   Json?            @db.JsonB
  expiresAt DateTime
  createdAt DateTime         @default(now())

  @@unique([email, type])
}

enum VerificationType {
  SIGNUP
  PASSWORD_RESET
}

model Company {
  id          String              @id @default(cuid())
  name        String
  address     String?
  createdBy   String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  owner       User                @relation(fields: [createdBy], references: [id])
  withdrawals CompanyWithdrawal[]
  customers   Customer[]
  investors   Investor[]
  partners    Partner[]
  payments    Payment[]
  sites       Site[]
  vendors     Vendor[]
  employees   Employee[]
}

model Partner {
  id              String    @id @default(cuid())
  companyId       String
  name            String
  email           String?
  phone           String?
  stakePercentage Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ledgerEntries   Payment[] @relation("PartnerLedgerEntries")
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Site {
  id          String     @id @default(cuid())
  companyId   String
  name        String
  address     String
  projectType String     @default("NEW_CONSTRUCTION")
  totalFloors Int?
  totalFlats  Int?
  slug        String     @unique
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  customers   Customer[]
  expenses    Expense[]
  floors      Floor[]
  investors   Investor[]
  payments    Payment[]
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Vendor {
  id        String    @id @default(cuid())
  companyId String
  name      String
  type      String
  phone     String?
  email     String?
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String      @id @default(cuid())
  siteId        String
  type          ExpenseType
  reason        String?
  vendorId      String?
  description   String?
  amount        Float
  isDeleted     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  ledgerEntries Payment[]   @relation("ExpenseLedgerEntries")
  site          Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  vendor        Vendor?     @relation(fields: [vendorId], references: [id])
}

model Floor {
  id          String   @id @default(cuid())
  siteId      String
  floorNumber Int
  createdAt   DateTime @default(now())
  floorName   String?
  flats       Flat[]
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model Flat {
  id           String     @id @default(cuid())
  floorId      String
  siteId       String
  flatNumber   Int?
  status       FlatStatus @default(AVAILABLE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  customFlatId String?
  unitType     String?
  flatType     String     @default("CUSTOMER")
  customer     Customer?
  floor        Floor      @relation(fields: [floorId], references: [id], onDelete: Cascade)
}

model Customer {
  id            String    @id @default(cuid())
  flatId        String?   @unique
  siteId        String?
  companyId     String
  name          String
  phone         String?
  email         String?
  customerType  String    @default("CUSTOMER")
  sellingPrice  Float
  bookingAmount Float
  dealStatus    CustomerDealStatus @default(ACTIVE)
  cancelledAt   DateTime?
  cancellationReason String?
  cancelledByUserId String?
  cancelledFromFlatStatus FlatStatus?
  cancelledFlatId String?
  cancelledFlatDisplay String?
  cancelledFloorNumber Int?
  cancelledFloorName String?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  ledgerEntries Payment[] @relation("CustomerLedgerEntries")
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  flat          Flat?     @relation(fields: [flatId], references: [id])
  site          Site?     @relation(fields: [siteId], references: [id])

  @@index([companyId, dealStatus, createdAt])
  @@index([siteId, dealStatus, createdAt])
}

model Investor {
  id               String                @id @default(cuid())
  companyId        String
  siteId           String?
  name             String
  phone            String?
  type             InvestorType
  equityPercentage Float?
  fixedRate        Float?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  isClosed         Boolean               @default(false)
  isDeleted        Boolean               @default(false)
  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site             Site?                 @relation(fields: [siteId], references: [id])
  transactions     InvestorTransaction[]
}

model InvestorTransaction {
  id            String                  @id @default(cuid())
  investorId    String
  kind          InvestorTransactionKind
  amount        Float
  note          String?
  isDeleted     Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  investor      Investor                @relation(fields: [investorId], references: [id], onDelete: Cascade)
  ledgerEntries Payment[]               @relation("InvestorTransactionLedgerEntries")
}

model CompanyWithdrawal {
  id            String    @id @default(cuid())
  companyId     String
  amount        Float
  note          String?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  ledgerEntries Payment[] @relation("CompanyWithdrawalLedgerEntries")
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Payment {
  id                    String               @id @default(cuid())
  companyId             String
  siteId                String?
  walletType            WalletType
  direction             Direction
  movementType          MovementType
  amount                Decimal              @db.Decimal(18, 2)
  postedAt              DateTime             @default(now())
  note                  String?
  idempotencyKey        String
  entryGroupId          String?
  customerId            String?
  expenseId             String?
  investorTransactionId String?
  companyWithdrawalId   String?
  partnerId             String?
  company               Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  site                  Site?                @relation(fields: [siteId], references: [id], onDelete: Restrict)
  customer              Customer?            @relation("CustomerLedgerEntries", fields: [customerId], references: [id])
  expense               Expense?             @relation("ExpenseLedgerEntries", fields: [expenseId], references: [id])
  investorTransaction   InvestorTransaction? @relation("InvestorTransactionLedgerEntries", fields: [investorTransactionId], references: [id])
  companyWithdrawal     CompanyWithdrawal?   @relation("CompanyWithdrawalLedgerEntries", fields: [companyWithdrawalId], references: [id])
  partner               Partner?             @relation("PartnerLedgerEntries", fields: [partnerId], references: [id])

  @@unique([companyId, idempotencyKey])
  @@index([companyId, walletType, postedAt])
  @@index([siteId, postedAt])
  @@index([movementType, postedAt])
}

model Employee {
  id            String                @id @default(cuid())
  companyId     String
  name          String
  email         String?
  phone         String
  address       String
  photo         String?
  employeeId    String
  designation   String
  department    String
  dateOfJoining DateTime
  salary        Float
  status        EmployeeStatus        @default(ACTIVE)
  isDeleted     Boolean               @default(false)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents     EmployeeDocument[]
  attendance    Attendance[]
  transactions  EmployeeTransaction[]
  reminders     SalaryReminder[]

  @@unique([companyId, employeeId])
  @@index([companyId, status, createdAt])
  @@index([companyId, department])
}

model EmployeeDocument {
  id           String   @id @default(cuid())
  employeeId   String
  documentType String
  documentName String
  fileUrl      String?
  keyValueData Json?    @db.JsonB
  uploadedAt   DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, uploadedAt])
}

model Attendance {
  id                  String           @id @default(cuid())
  employeeId          String
  date                DateTime
  status              AttendanceStatus
  checkInTime         DateTime?
  checkOutTime        DateTime?
  reasonOfAbsenteeism String?
  markedBy            String
  createdAt           DateTime         @default(now())
  employee            Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, date])
}

model EmployeeTransaction {
  id            String                    @id @default(cuid())
  employeeId    String
  type          EmployeeTransactionType
  amount        Float
  description   String
  date          DateTime
  paymentMethod EmployeePaymentMethod?
  status        EmployeeTransactionStatus @default(PENDING)
  createdAt     DateTime                  @default(now())
  paidAt        DateTime?
  employee      Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@index([employeeId, type, status])
}

model SalaryReminder {
  id           String              @id @default(cuid())
  employeeId   String
  month        Int
  year         Int
  salaryAmount Float
  dueDate      DateTime
  status       SalaryReminderStatus @default(PENDING)
  reminderSent Boolean             @default(false)
  createdAt    DateTime            @default(now())
  paidAt       DateTime?
  transactionId String?
  employee     Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([year, month, status])
}

enum ExpenseType {
  GENERAL
  VENDOR
}

enum FlatStatus {
  AVAILABLE
  BOOKED
  SOLD
}

enum CustomerDealStatus {
  ACTIVE
  CANCELLED
}

enum InvestorType {
  EQUITY
  FIXED_RATE
}

enum MovementType {
  PARTNER_CAPITAL_IN
  CUSTOMER_PAYMENT
  CUSTOMER_REFUND
  EXPENSE_PAYMENT
  INVESTOR_PRINCIPAL_IN
  INVESTOR_PRINCIPAL_OUT
  INVESTOR_INTEREST
  COMPANY_WITHDRAWAL
  COMPANY_TO_SITE_TRANSFER
  SITE_TO_COMPANY_TRANSFER
  REVERSAL
  ADJUSTMENT
}

enum Direction {
  IN
  OUT
}

enum WalletType {
  COMPANY
  SITE
}

enum InvestorTransactionKind {
  PRINCIPAL_IN
  PRINCIPAL_OUT
  INTEREST
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum EmployeeTransactionType {
  SALARY
  BONUS
  DEDUCTION
  ADVANCE
  REIMBURSEMENT
}

enum EmployeePaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
}

enum EmployeeTransactionStatus {
  PENDING
  PAID
  FAILED
}

enum SalaryReminderStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
}
